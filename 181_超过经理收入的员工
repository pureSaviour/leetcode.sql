CREATE schema IF NOT EXISTS _181;
SET search_path TO _181;

CREATE TABLE Employee(
    id INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
    name VARCHAR(255) NOT NULL,
    salary INT NOT NULL,
    managerId INT
);

DELETE FROM Employee;
ALTER TABLE Employee 
ALTER COLUMN id RESTART WITH 1;

INSERT INTO Employee (name, salary, managerId)
WITH 
employee_list AS (
    SELECT id AS emp_id,
    'Employee' || id AS name,
    (floor((random() * 50 + 1)) * 1000) AS salary,
    random() < 0.2 AS is_manager
    FROM generate_series(1, 100) AS id
),
manager_idlist AS (
    SELECT array_agg(emp_id) AS manager_ids
    FROM employee_list
    WHERE is_manager
)
SELECT
    name,
    salary,
    CASE
        WHEN is_manager THEN NULL
        ELSE manager_ids[floor(random() * array_length(manager_ids, 1)) + 1]
    END AS managerId
    FROM employee_list, manager_idlist;      

SELECT e1.name AS Employee
FROM Employee e1  JOIN Employee e2 
ON e1.managerId = e2.id
WHERE e1.salary > e2.salary;