CREATE SCHEMA IF NOT EXISTS _262;
SET search_path TO _262;

CREATE TYPE BanStatus AS ENUM (
    'Yes',
    'No'
);
CREATE TYPE Role AS ENUM(
    'Client',
    'Driver'
);
CREATE TYPE TripStatus AS ENUM(
    'Completed',
    'Cancelled_By_Client',
    'Cancelled_By_Driver'
);

CREATE TABLE IF NOT EXISTS Users(
    users_id INT PRIMARY KEY,
    banned BanStatus NOT NULL,
    role Role NOT NULL
);

CREATE TABLE IF NOT EXISTS Trips(
    id INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY,
    client_id INT NOT NULL,
    driver_id INT NOT NULL,
    city_id INT NOT NULL DEFAULT floor(random() * 20 + 1),
    status TripStatus NOT NULL,
    request_at VARCHAR(20) NOT NULL,
    FOREIGN KEY (client_id) REFERENCES Users(users_id),
    FOREIGN KEY (driver_id) REFERENCES Users(users_id)
);


INSERT INTO Users (
    SELECT 
        floor(random() * 100)::INT + 1 AS users_id,
        CASE WHEN random() < 0.1 THEN 'Yes'::BanStatus ELSE 'No'::BanStatus END AS banned,
        CASE WHEN random() < 0.5 THEN 'Client'::Role ELSE 'Driver'::Role END AS role
    FROM generate_series(1, 1000)
    ORDER BY users_id
) ON CONFLICT (users_id) DO NOTHING;

CREATE OR REPLACE FUNCTION random_client()
RETURNS INT AS $$
BEGIN 
    RETURN (SELECT users_id
    FROM users
    WHERE role = 'Client'::Role
    ORDER BY random()
    LIMIT 1);
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION random_driver()
RETURNS INT AS $$
BEGIN 
    RETURN (SELECT users_id
    FROM users
    WHERE role = 'Driver'::Role
    ORDER BY random()
    LIMIT 1);
END
$$ LANGUAGE plpgsql;

INSERT INTO Trips (client_id, driver_id, status, request_at) (
    SELECT
        random_client() AS client_id,
        random_driver() AS driver_id,
        CASE 
            WHEN random() < 0.7 THEN 'Completed'::TripStatus
            WHEN random() < 0.85 THEN 'Cancelled_By_Client'::TripStatus
            ELSE 'Cancelled_By_Driver'::TripStatus
        END AS status,
        to_char(
            '2013-09-29'::DATE + (random() * ('2013-10-05'::DATE - '2013-09-29'::DATE))::INT,
            'YYYY-MM-DD'
        ) AS request_at
    FROM generate_series(1, 1000)
);

DELETE FROM users;
DELETE FROM trips;
ALTER SEQUENCE trips_id_seq RESTART WITH 1;
SELECT * FROM users;
SELECT * FROM trips;

WITH not_banned_trip AS (
    SELECT 
        id,
        client_id,
        driver_id,
        status,
        request_at,
        uc.users_id,
        ud.users_id
    FROM Trips 
    JOIN Users uc
    ON client_id = uc.users_id AND uc.banned = 'No' AND uc.role = 'Client'
    JOIN Users ud 
    ON driver_id = ud.users_id AND ud.banned = 'No' AND ud.role = 'Driver'
    WHERE request_at::DATE BETWEEN '2013-10-01'::DATE AND '2013-10-03'::DATE
    ORDER BY id
), 
complete_trip AS (
    SELECT 
        request_at,
        count(*) FILTER (WHERE status = 'Completed') / count(*)::NUMERIC AS complete_rate
    FROM not_banned_trip
    GROUP BY request_at
)
SELECT 
    request_at AS Day,
    round(1 - complete_rate, 2) As "Cancellation Rate"
FROM complete_trip;